# ─── PlaceToPay Credentials ────────────────────────────────────
# SANDBOX → https://checkout-test.placetopay.com
# PRODUCCIÓN → https://checkout.placetopay.com
PLACETOPAY_LOGIN=your_login_here
PLACETOPAY_TRANKEY=your_trankey_here
PLACETOPAY_ENV=sandbox

# ─── MongoDB Atlas ─────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/?appName=LaIndustriaBolera

# ─── Server Config ─────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173

# ─── Seguridad (obligatorio en producción) ─────────────────────
# Generar valores aleatorios largos (32+ caracteres) — nunca commitear los reales
ADMIN_JWT_SECRET=
PAYMENT_ACCESS_SECRET=
CRON_SECRET=

# ─── Admin bootstrap (solo desarrollo / primera instalación) ───
# ADMIN_BOOTSTRAP_PASSWORD=  # contraseña inicial si no existen usuarios
# ALLOW_ADMIN_SEED=true      # permitir seed de usuarios en producción (solo migración)
# ALLOW_ADMIN_MASTER=true    # permitir ADMIN_MASTER_PASSWORD en producción (no recomendado)

# ─── Netlify (producción) ─────────────────────────────────────
# Configurar en Netlify Dashboard > Site settings > Environment variables:
#   PLACETOPAY_LOGIN, PLACETOPAY_TRANKEY, PLACETOPAY_ENV=production
#   MONGODB_URI, ADMIN_JWT_SECRET, PAYMENT_ACCESS_SECRET, CRON_SECRET
#   FRONTEND_URL=https://laindustriabolera.co
